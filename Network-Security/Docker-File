FROM ubuntu:latest

# Install the broker application package inside the sandbox environment
RUN apt-get update && apt-get install -y mosquitto && rm -rf /var/lib/apt/lists/*

# Copy container-optimized configurations and security assets
COPY config/mosquitto_container.conf /etc/mosquitto/mosquitto.conf
COPY config/medical_acl.conf /etc/mosquitto/medical_acl.conf
COPY certs/ca.crt /etc/mosquitto/ca.crt
COPY certs/server.crt /etc/mosquitto/server.crt
COPY certs/server.key /etc/mosquitto/server.key

# Secure file ownership mapping inside the sandbox layout
RUN chown -R mosquitto:mosquitto /etc/mosquitto

# Enforce Least Privilege Principle: Drop root privileges entirely
USER mosquitto

EXPOSE 8883
CMD ["mosquitto", "-c", "/etc/mosquitto/mosquitto.conf"]
